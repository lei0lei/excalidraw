MODE="production"

# Optional: custom app URLs / services
VITE_APP_BACKEND_V2_GET_URL=
VITE_APP_BACKEND_V2_POST_URL=
VITE_APP_LIBRARY_URL=
VITE_APP_LIBRARY_BACKEND=
VITE_APP_WS_SERVER_URL=
VITE_APP_PLUS_LP=
VITE_APP_PLUS_APP=
VITE_APP_AI_BACKEND=
VITE_APP_FIREBASE_CONFIG=

# Build/runtime flags
VITE_APP_ENABLE_TRACKING=true
VITE_APP_ENABLE_PWA=true
VITE_APP_ENABLE_ESLINT=false
VITE_APP_COLLAPSE_OVERLAY=true

# Google Drive Workspace integration
VITE_APP_GOOGLE_CLIENT_ID=
VITE_APP_GOOGLE_API_KEY=
VITE_APP_GOOGLE_APP_ID=

# PWA branding
VITE_APP_PWA_SHORT_NAME=Excalidraw
VITE_APP_PWA_NAME=Excalidraw Workspace
VITE_APP_PWA_DESCRIPTION=Excalidraw with Google Drive and local workspace support.
VITE_APP_PWA_THEME_COLOR=#121212
VITE_APP_PWA_BACKGROUND_COLOR=#ffffff
